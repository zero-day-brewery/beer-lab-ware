{
  "name": "beer-lab-ware",
  "version": "0.2.0",
  "description": "Offline-first homebrewing recipe, brew-day, and fermentation PWA",
  "license": "MIT",
  "author": "Zero-Day Brewery",
  "repository": {
    "type": "git",
    "url": "https://github.com/zero-day-brewery/beer-lab-ware"
  },
  "homepage": "https://github.com/zero-day-brewery/beer-lab-ware",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/inject-csp.mjs && node scripts/gen-sw-precache.mjs",
    "serve": "serve out -l 3030 --no-port-switching --no-clipboard",
    "mcp": "tsx src/lib/node/mcp-server.ts",
    "build:daemon": "node scripts/build-daemon.mjs",
    "lint": "biome check ./src ./tests ./e2e",
    "format": "biome format --write ./src ./tests ./e2e",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "sync": "tsx src/lib/node/sync-server.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dexie": "^4.4.4",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^1.26.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.10",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "serve": "^14.2.4",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.22",
    "sharp": "^0.35.3"
  }
}
