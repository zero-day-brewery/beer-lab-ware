# Beer-Lab-Ware sync daemon — environment  [copy to /etc/beer-lab-ware/sync.env, chmod 0600]
#
# NEVER commit the real file. Owned by the `beerlab` user, 0600.

# Path to the canonical brewery.json (DumpV9). Put it on storage that survives
# reboots/redeploys of this host.
BREWERY_FILE=/var/lib/beer-lab-ware/brewery.json

# Comma-separated sha256-HEX hashes of the valid, enabled per-device tokens.
# The daemon stores only hashes (compared with timingSafeEqual); the plaintext
# tokens live client-side (localStorage/appMeta, backup-excluded) and NOWHERE here.
#   Generate a token + its hash on a trusted machine (see docs/deploy/README.md
#   "Token lifecycle" for why `printf` + `cut` matter — a plain `shasum` copy
#   includes a trailing marker that fails the hash-format check below):
#     TOK=$(openssl rand -hex 32); echo "token (give to the device): $TOK"
#     printf '%s' "$TOK" | shasum -a 256 | cut -d' ' -f1   # → the hash to add below
#   Revoke a device = delete its hash from this list + restart the daemon.
SYNC_TOKEN_HASHES=

# Daemon listen port (loopback only; your reverse proxy forwards to it).
SYNC_PORT=8787

# Prior generations of brewery.json to retain as `<file>.<timestamp>.bak` before
# each PUT overwrite (see "Restoring from a generation" in README.md). One
# integer >= 0; 0 disables generation backups entirely. Default 10 if unset.
SYNC_KEEP_GENERATIONS=10

# OPT-IN CORS — leave UNSET for the reference deploy. With the Caddyfile in this
# folder the app and daemon share ONE origin, so the browser never needs CORS and
# the daemon (correctly) emits no CORS headers at all. Set this ONLY when the app
# is served from a DIFFERENT origin than this daemon (e.g. a hosted PWA pointing
# at your self-hosted daemon): comma-separated EXACT origins, scheme://host[:port],
# no paths, no trailing slash, NO wildcards (a `*` entry refuses to start — see
# "Cross-origin apps" in docs/deploy/README.md for why).
#   SYNC_ALLOWED_ORIGINS=https://app.example.com,https://your-name.github.io
#SYNC_ALLOWED_ORIGINS=
